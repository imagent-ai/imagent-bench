{
  "benchmark_version": "openrouter-vision-v1.1.0",
  "dataset_version": "openrouter-vision-v1.1.0",
  "suite": "openrouter_vision_v1",
  "agent_config": {
    "runtime": {
      "max_feedback_rounds": 1,
      "candidates_per_round": 2
    },
    "agent": {
      "image_backend": {
        "mode": "live",
        "provider": "openrouter",
        "api_key_env": "OPENROUTER_API_KEY",
        "endpoint": "https://openrouter.ai/api/v1/images",
        "model": "google/gemini-3.1-flash-image",
        "resolution": "1K",
        "aspect_ratio": "1:1",
        "output_format": "png",
        "send_seed": false,
        "send_output_format": false,
        "timeout_seconds": 240,
        "referer": "https://tryimagent.com",
        "title": "imagent benchmark"
      },
      "verifier": {
        "provider": "openrouter_vision",
        "api_key_env": "OPENROUTER_API_KEY",
        "model": "google/gemini-2.5-flash",
        "timeout_seconds": 180,
        "referer": "https://tryimagent.com",
        "title": "imagent internal verifier"
      }
    },
    "evaluation": {
      "image_judge": {
        "provider": "openrouter_vision",
        "api_key_env": "OPENROUTER_API_KEY",
        "model": "google/gemini-2.5-flash",
        "rubric_version": "openrouter-vision-v1",
        "temperature": 0,
        "max_tokens": 1200,
        "timeout_seconds": 180,
        "referer": "https://tryimagent.com",
        "title": "imagent benchmark judge",
        "dimensions": {
          "prompt_alignment": 0.35,
          "visual_quality": 0.2,
          "aesthetics": 0.15,
          "text_accuracy": 0.15,
          "layout_and_composition": 0.1,
          "realism": 0.05
        }
      }
    }
  },
  "execution": {
    "install": false
  },
  "policy": {
    "minimum_score": 75.0,
    "max_failed_cases": 0,
    "max_cost_usd": 5.0,
    "max_latency_p95_ms": 300000.0,
    "minimum_merge_improvement": 1.0,
    "improvement_thresholds": {
      "minor": 1.0,
      "strong": 3.0,
      "major": 7.0
    }
  }
}
