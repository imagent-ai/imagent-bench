{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imagent-ai.dev/schemas/benchmark-report.schema.json",
  "title": "imagent benchmark report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "repository",
    "commit_sha",
    "benchmark_version",
    "dataset_version",
    "status",
    "overall_score",
    "metrics",
    "cases",
    "artifacts",
    "logs",
    "configuration",
    "policy",
    "started_at",
    "completed_at",
    "execution_time_ms"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string"},
    "repository": {"type": "string"},
    "commit_sha": {"type": "string"},
    "benchmark_version": {"type": "string"},
    "dataset_version": {"type": "string"},
    "status": {"enum": ["pass", "fail"]},
    "overall_score": {"type": "number", "minimum": 0, "maximum": 100},
    "metrics": {"type": "object"},
    "cases": {"type": "array"},
    "artifacts": {"type": "array"},
    "logs": {"type": "array"},
    "configuration": {"type": "object"},
    "policy": {"type": "object"},
    "started_at": {"type": "string"},
    "completed_at": {"type": "string"},
    "execution_time_ms": {"type": "number", "minimum": 0}
  }
}
