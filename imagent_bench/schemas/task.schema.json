{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "capability", "prompt", "expected"],
  "properties": {
    "id": {"type": "string"},
    "capability": {"type": "string"},
    "prompt": {"type": "string"},
    "assets": {"type": "array", "items": {"type": "string"}},
    "allowed_tools": {"type": "array", "items": {"type": "string"}},
    "expected": {
      "type": "object",
      "required": ["checks"],
      "properties": {
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {"type": "string"},
              "value": {},
              "values": {"type": "array"}
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
