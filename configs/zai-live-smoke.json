{
  "benchmark_version": "zai-live-smoke-v1",
  "dataset_version": "zai-live-smoke-v1.0.0",
  "suite": "zai_live_smoke",
  "agent_config": {
    "runtime": {
      "max_feedback_rounds": 0,
      "candidates_per_round": 1
    },
    "agent": {
      "image_backend": {
        "mode": "live",
        "provider": "zai",
        "api_key_env": "ZAI_API_KEY",
        "endpoint": "https://api.z.ai/api/paas/v4/images/generations",
        "model": "glm-image",
        "size": "1024x1024",
        "quality": "standard",
        "output_format": "png",
        "send_seed": false,
        "send_output_format": false,
        "timeout_seconds": 240
      },
      "verifier": {
        "provider": "mock_text"
      }
    },
    "evaluation": {
      "image_judge": {
        "provider": "mock_text"
      }
    }
  },
  "execution": {
    "install": false
  },
  "policy": {
    "minimum_score": 100.0,
    "max_failed_cases": 0,
    "max_cost_usd": 999.0,
    "max_latency_p95_ms": 300000.0
  }
}
