{
  "benchmark_version": "openrouter-live-smoke-v1",
  "dataset_version": "openrouter-live-smoke-v1.0.0",
  "suite": "openrouter_live_smoke",
  "agent_config": {
    "runtime": {
      "max_feedback_rounds": 0,
      "candidates_per_round": 1
    },
    "agent": {
      "image_backend": {
        "mode": "live",
        "provider": "openrouter",
        "api_key_env": "OPENROUTER_API_KEY",
        "endpoint": "https://openrouter.ai/api/v1/images",
        "model": "google/gemini-3.1-flash-image",
        "resolution": "1K",
        "aspect_ratio": "1:1",
        "output_format": "png",
        "send_seed": false,
        "send_output_format": false,
        "timeout_seconds": 240,
        "referer": "https://tryimagent.com",
        "title": "imagent live smoke"
      },
      "verifier": {
        "provider": "mock_text"
      }
    },
    "evaluation": {
      "image_judge": {
        "provider": "mock_text"
      }
    }
  },
  "execution": {
    "install": false
  },
  "policy": {
    "minimum_score": 100.0,
    "max_failed_cases": 0,
    "max_cost_usd": 999.0,
    "max_latency_p95_ms": 300000.0
  }
}
